{
  "name": "codecraft-desktop",
  "version": "1.0.1",
  "description": "CodeCraft 桌面应用（Electron）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env DEV_MODE=true electron .",
    "pack": "npm install electron-builder && electron-builder --dir",
    "dist": "npm install electron-builder && electron-builder"
  },
  "build": {
    "appId": "com.codecraft.app",
    "productName": "CodeCraft",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "package.json",
      "icon.png"
    ],
    "icon": "icon.ico",
    "extraResources": [
      {
        "from": "../target/codecraft-1.0.1.jar",
        "to": "backend/codecraft.jar"
      },
      {
        "from": "jre",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
