{
  "name": "codecraft-desktop",
  "version": "1.0.2",
  "description": "CodeCraft 桌面应用（Electron）",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env DEV_MODE=true electron .",
    "pack": "npm install electron-builder && electron-builder --dir",
    "dist": "npm install electron-builder && electron-builder",
    "dist:win": "npm install electron-builder && electron-builder --win",
    "dist:mac": "npm install electron-builder && electron-builder --mac",
    "dist:linux": "npm install electron-builder && electron-builder --linux"
  },
  "build": {
    "appId": "com.codecraft.app",
    "productName": "CodeCraft",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../target/codecraft-1.0.2.jar",
        "to": "backend/codecraft.jar"
      },
      {
        "from": "jre",
        "to": "jre",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "无需使用麦克风",
        "NSCameraUsageDescription": "无需使用摄像头"
      }
    },
    "dmg": {
      "title": "CodeCraft",
      "icon": "icon.icns",
      "background": "dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file",
          "path": "CodeCraft.app"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "icon.png",
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "cross-env": "^7.0.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  }
}
