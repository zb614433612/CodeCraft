# ==========================================
# 环境变量配置示例（本文件不生效，仅供参考）
# ==========================================
# 项目实际加载优先级：
#   1. application-local.yml（最高，推荐方式）
#   2. 系统环境变量
#   3. application.yml 中的默认值（__MUST_CONFIGURE_xxx__）
#
# 推荐方式：复制 application-local.yml.example 为 application-local.yml
# 并填入实际密码，该文件已在 .gitignore 中，不会提交到 Git
# ==========================================

# MySQL 数据库密码
DB_PASSWORD=your_mysql_password

# Redis 主机地址（默认 localhost）
REDIS_HOST=localhost

# Redis 密码
REDIS_PASSWORD=your_redis_password

# DeepSeek API 密钥
DEEPSEEK_API_KEY=sk-your-api-key-here
