# ==========================================
# 环境变量配置示例
# 复制本文件为 .env 或直接设置系统环境变量
# ==========================================

# MySQL 数据库密码
DB_PASSWORD=your_mysql_password

# Redis 主机地址（默认 localhost）
REDIS_HOST=localhost

# Redis 密码
REDIS_PASSWORD=your_redis_password

# DeepSeek API 密钥
DEEPSEEK_API_KEY=sk-your-api-key-here
