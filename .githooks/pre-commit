#!/bin/sh
#
# pre-commit hook — 提交前自动编译检查
# 如果编译失败，拒绝提交，避免"改了代码就跑"的问题
#

echo "🔍 [pre-commit] 正在编译后端代码..."

# 检查 Maven 位置
MAVEN=""
if command -v mvn >/dev/null 2>&1; then
    MAVEN="mvn"
elif [ -f "E:/apache-maven-3.9.9/bin/mvn.cmd" ]; then
    MAVEN="E:/apache-maven-3.9.9/bin/mvn.cmd"
elif [ -f "mvnw" ]; then
    MAVEN="./mvnw"
else
    echo "⚠️  [pre-commit] 找不到 Maven，跳过编译检查"
    exit 0
fi

# 只检查 Java 文件变更（跳过纯前端/文档修改）
STAGED_JAVA=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.java$' || true)
if [ -z "$STAGED_JAVA" ]; then
    echo "✅ [pre-commit] 无 Java 文件变更，跳过编译检查"
    exit 0
fi

# 执行编译
$MAVEN compile -q 2>&1
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo ""
    echo "❌ [pre-commit] 编译失败！请修复后再提交"
    echo "   运行 mvn compile 查看详细错误"
    echo ""
    echo "   如果你确定要跳过检查强制提交，执行:"
    echo "   git commit --no-verify -m \"你的提交信息\""
    exit 1
fi

echo "✅ [pre-commit] 编译通过"
exit 0
