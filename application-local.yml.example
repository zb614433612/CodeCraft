# ============================================================
# 本地环境配置模板
# 复制本文件为 application-local.yml 并填入实际密码
# application-local.yml 已在 .gitignore 中，不会提交到 Git
#
# 为什么用这个文件而不是环境变量？
# - application-local.yml 是 Spring Boot profile 配置，优先级高于 application.yml
# - 和项目在同一目录，方便管理
# - 比系统环境变量更直观，不需要修改系统配置
# ============================================================

# MySQL 数据库密码
spring:
  datasource:
    password: 你的数据库密码
  data:
    redis:
      # Redis 主机地址
      host: localhost
      # Redis 密码
      password: 你的Redis密码

# DeepSeek API 密钥
deepseek:
  api-key: sk-你的API密钥
